            <div class="info-textbox">
                <p>Hier kommt ein text der erklärt warum es diese Website gibt.</p>
            </div>
        </div>

        <!-- first content wrapper -->
        <div class="info-row">
            <div class="info-textbox">
                <p>Hier kommt ein text der erklärt warum es diese Website gibt.</p>
            </div>
            
            <div class="info-image">
                <img src="" alt="">
            </div>
        </div>
    </section>


    <!-- MOST VIEWD TAKES SECTION -->
    <section class="popular-takes">
        <h2 class="page-title">popular takes.</h2>

        <div class="slider">
            <!-- visible Article Window -->
            <div class="slider-track">
                <!-- Article -->
                <a href="/takes/article-slug" class="article-card">
                    <div class="article-card-image"></div>
                    <span class="article-card-author">AUTHOR NAME</span>
                    <h4 class="article-card-title">Article title goes here</h4>
                </a>
                <!-- Article -->
                <a href="/takes/article-slug" class="article-card">
                    <div class="article-card-image"></div>
                    <span class="article-card-author">AUTHOR NAME</span>
                    <h4 class="article-card-title">Article title goes here</h4>
                </a>
                <!-- Article -->
                <a href="/takes/article-slug" class="article-card">
                    <div class="article-card-image"></div>
                    <span class="article-card-author">AUTHOR NAME</span>
                    <h4 class="article-card-title">Article title goes here</h4>
                </a>
            </div>
        </div>
    </section>


    <!-- CONTACT US SECTION -->
    <section class="contact">
        <h2 class="page-title">questions.</h2>

        <div class="contact-wrapper">

            <!-- left panel: contact info -->
            <div class="contact-info-panel">
                <div class="contact-info-fields">
                    <div class="contact-info-item">
                        <span class="contact-info-label">Email</span>
                        <span class="contact-info-value">contact@coldtake.com</span>
                    </div>
                    <div class="contact-info-item">
                        <span class="contact-info-label">Phone</span>
                        <span class="contact-info-value">+49 123 456790</span>
                    </div>
                    <div class="contact-info-item">
                        <span class="contact-info-label">Address</span>
                        <span class="contact-info-value">coldtake<br>Donaustraße 44,<br>12043 Berlin</span>
                    </div>
                </div>
                <h3 class="form-title">contact us.</h3>
            </div>

            <!-- right panel: contact form -->
            <div class="contact-form-panel">
                <form class="contact-form" action="/" method="post">
                    <div class="contact-form-row">
                    <div class="contact-form-field">
                        <label for="name">Name</label>
                        <input type="text" id="name" name="user_name" placeholder="Your full name">
                    </div>
                    <div class="contact-form-field">
                        <label for="email">Email </label>
                        <input type="email" id="email" name="user_email" placeholder="Your Email address">
                    </div>
                    </div>
                    <div class="contact-form-field contact-form-field--full">
                        <label for="message">Message</label>
                        <textarea id="message" name="user_message" placeholder="Write something..."></textarea>
                    </div>
                    <button type="submit">Send Message</button>
                </form>
            </div>
        </div>
    </section>

</main>

<%- include('partials/footer') %>




 